# Azure DevOps Token (Personal Access Token)
# Obtener en: https://dev.azure.com/{organization}/_usersSettings/tokens
# Permisos necesarios: Work Items (Read)
AZURE_DEVOPS_TOKEN=your-personal-access-token-here

# Configuración de Azure DevOps
AZURE_DEVOPS_ORG=Grupo-KFC
AZURE_DEVOPS_PROJECT=SIR

# Opcional: Configuración adicional
# AZURE_DEVOPS_API_VERSION=7.0

# ── GitHub: push automático de document.json ─────────────────────────────────
# Sin token → usa git push SSH (desarrollo local).
# Con token → usa GitHub REST API (recomendado en contenedor).
# Crear en: https://github.com/settings/tokens → Fine-grained → Contents (Read & Write)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_OWNER=ByronAnto
# GITHUB_REPO=SIR_timeline
# GITHUB_BRANCH=main

# Carpeta donde se guardan los adjuntos y Excel de cada versión.
# Por defecto: ~/Descargas (Linux) o ~/Downloads (Windows/Mac)
# DOWNLOADS_PATH=/home/usuario/Descargas
